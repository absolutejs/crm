{
  "name": "@absolutejs/crm",
  "version": "0.0.10-alpha.8",
  "description": "Multi-vendor CRM adapter framework for AbsoluteJS",
  "repository": {
    "type": "git",
    "url": "https://github.com/absolutejs/crm.git"
  },
  "homepage": "https://github.com/absolutejs/crm",
  "bugs": {
    "url": "https://github.com/absolutejs/crm/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "BSL-1.1",
  "author": "Alex Kahn",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./manifest.json": "./dist/manifest.json"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/manifest.ts --root ./src --outdir dist --target=bun --external elysia --external citra --external @absolutejs/auth --external @absolutejs/voice --external jsforce --external @hubspot/api-client --external @mondaydotcomorg/api && tsc --emitDeclarationOnly --project tsconfig.json && absolute-manifest emit",
    "config": "absolute config",
    "test": "bun test",
    "typecheck": "bun run tsc --noEmit",
    "lint": "echo 'lint not yet wired'",
    "format": "prettier --write \"./**/*.{js,ts,json}\""
  },
  "keywords": [
    "crm",
    "salesforce",
    "hubspot",
    "pipedrive",
    "zoho",
    "absolutejs",
    "elysia"
  ],
  "peerDependencies": {
    "@absolutejs/auth": ">=0.56.17 <1",
    "@absolutejs/voice": ">=0.0.22-beta.643 <0.1",
    "citra": ">=0.29.7 <1",
    "elysia": ">=1.4.26"
  },
  "peerDependenciesMeta": {
    "@absolutejs/voice": {
      "optional": true
    },
    "elysia": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@hubspot/api-client": "^12.0.0",
    "@mondaydotcomorg/api": "^9.0.0",
    "jsforce": "^3.0.0"
  },
  "devDependencies": {
    "@absolutejs/absolute": "^0.19.0-beta.1051",
    "@absolutejs/auth": "0.56.17",
    "@absolutejs/voice": "0.0.22-beta.644",
    "@types/bun": "1.3.14",
    "citra": "0.29.7",
    "drizzle-orm": "1.0.0-rc.4",
    "elysia": "1.4.28",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@absolutejs/manifest": "^0.1.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "absolutejs": {
    "manifestContract": 1
  }
}
